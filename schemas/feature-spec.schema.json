{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/feature-spec.schema.json",
  "title": "Shirube Feature Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "SPEC-ID",
    "risk_tier",
    "background",
    "purpose",
    "non_goals",
    "requirements",
    "acceptance_criteria",
    "test_plan",
    "rollback_plan"
  ],
  "properties": {
    "schema_version": { "const": "shirube-feature-spec/v1" },
    "SPEC-ID": { "type": "string", "pattern": "^SPEC-[A-Z0-9-]+$" },
    "risk_tier": { "$ref": "#/$defs/riskTier" },
    "background": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "non_goals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "target_users": { "type": "array", "items": { "type": "string" } },
    "target_scope": { "type": "array", "items": { "type": "string" } },
    "changed_areas": { "type": "array", "items": { "type": "string" } },
    "requirements": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/requirement" } },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/criterion" } },
    "negative_cases": { "type": "array", "items": { "$ref": "#/$defs/criterion" } },
    "non_functional_requirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "security": { "type": "string" },
        "privacy": { "type": "string" },
        "ai_usage": { "type": "string" },
        "data": { "type": "string" },
        "api": { "type": "string" },
        "db": { "type": "string" },
        "audit_log": { "type": "string" }
      }
    },
    "migration_plan": { "type": "string" },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "test_plan": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/testPlanItem" } },
    "unresolved_questions": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "riskTier": { "enum": ["R0", "R1", "R2", "R3"] },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement"],
      "properties": {
        "id": { "type": "string", "pattern": "^(REQ|SEC|NFR|AI|DATA)-[A-Z0-9-]+$" },
        "statement": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "linked_requirements"],
      "properties": {
        "id": { "type": "string", "pattern": "^AC-[A-Z0-9-]+$" },
        "statement": { "type": "string", "minLength": 1 },
        "linked_requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "testPlanItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "linked_requirements"],
      "properties": {
        "id": { "type": "string", "pattern": "^TEST-[A-Z0-9-]+$" },
        "description": { "type": "string" },
        "linked_requirements": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
