{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/shirube-audit.schema.json",
  "title": "Shirube Audit v1",
  "description": "Canonical Shirube audit output and audit item set schema for unified list-backed reconciliation and list-driven semantic audit records.",
  "oneOf": [
    { "$ref": "#/$defs/audit_record" },
    { "$ref": "#/$defs/audit_item_set" }
  ],
  "$defs": {
    "stage": {
      "enum": [
        "stage-3",
        "stage-6",
        "stage-9",
        "bridge"
      ]
    },
    "audit_type": {
      "enum": [
        "spec-audit",
        "impl-audit",
        "trace-audit",
        "conformance-audit",
        "bridge-admissibility"
      ]
    },
    "aggregate_verdict": {
      "enum": ["PASS", "PASS_WITH_WARN", "BLOCKED", "FAIL"]
    },
    "audit_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "audit_id",
        "audit_type",
        "stage",
        "reviewer_actor",
        "reviewer_model",
        "target_head",
        "target_refs",
        "item_set_ref",
        "matched_items",
        "missing_items",
        "extra_items",
        "conflicting_items",
        "items",
        "aggregate_verdict"
      ],
      "properties": {
        "schema_version": { "const": "shirube-audit/v1" },
        "document_type": { "const": "audit_record" },
        "audit_id": { "type": "string", "pattern": "^AUDIT-[A-Z0-9-]+$" },
        "audit_type": { "$ref": "#/$defs/audit_type" },
        "stage": { "$ref": "#/$defs/stage" },
        "reviewer_actor": { "type": "string", "minLength": 1 },
        "reviewer_model": { "type": "string", "minLength": 1 },
        "target_head": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "target_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "item_set_ref": { "type": "string", "minLength": 1 },
        "matched_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/reconciliation_item" }
        },
        "missing_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/reconciliation_item" }
        },
        "extra_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/reconciliation_item" }
        },
        "conflicting_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/reconciliation_item" }
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/audit_item_result" }
        },
        "aggregate_verdict": { "$ref": "#/$defs/aggregate_verdict" }
      }
    },
    "reconciliation_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_ref": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "audit_item_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "verdict",
        "reason",
        "evidence_ref"
      ],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "verdict": { "enum": ["PASS", "FAIL", "N/A", "UNVERIFIED"] },
        "reason": { "type": "string", "minLength": 1 },
        "evidence_ref": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "verdict": { "const": "FAIL" }
            },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "evidence_ref": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "audit_item_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "document_type",
        "item_set_id",
        "stage",
        "items"
      ],
      "properties": {
        "schema_version": { "const": "shirube-audit/v1" },
        "document_type": { "const": "audit_item_set" },
        "item_set_id": { "type": "string", "pattern": "^AUDIT-ITEM-SET-[A-Z0-9-]+$" },
        "stage": { "$ref": "#/$defs/stage" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/audit_item" }
        }
      }
    },
    "audit_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "criterion",
        "required_evidence"
      ],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "criterion": { "type": "string", "minLength": 1 },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
