{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/impl.schema.json",
  "title": "Shirube Cell Impl",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "IMPL-ID",
    "CELL-ID",
    "SPEC-ID",
    "covered_req_ids",
    "planned_file_changes",
    "implementation_order",
    "tests_to_add_or_update",
    "risks",
    "rollback_method"
  ],
  "properties": {
    "schema_version": { "const": "shirube-impl/v1" },
    "IMPL-ID": { "type": "string", "pattern": "^IMPL-[A-Z0-9-]+$" },
    "CELL-ID": { "type": "string", "pattern": "^CELL-[A-Z0-9-]+$" },
    "SPEC-ID": { "type": "string", "pattern": "^SPEC-[A-Z0-9-]+$" },
    "covered_req_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "planned_file_changes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/plannedFileChange" } },
    "planned_functions_types_modules": { "type": "array", "items": { "type": "string" } },
    "api_changes": { "type": "array", "items": { "type": "string" } },
    "db_changes": { "type": "array", "items": { "type": "string" } },
    "auth_and_permission_handling": { "type": "string" },
    "error_handling": { "type": "string" },
    "logging_and_audit_logging": { "type": "string" },
    "tests_to_add_or_update": { "type": "array", "items": { "type": "string" } },
    "implementation_order": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "rollback_method": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "plannedFileChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "change_type", "reason"],
      "properties": {
        "path": { "type": "string" },
        "change_type": { "enum": ["add", "modify", "delete"] },
        "reason": { "type": "string" },
        "linked_req_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
