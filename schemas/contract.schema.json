{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/contract.schema.json",
  "title": "Shirube Cross-repo Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "CONTRACT-ID",
    "contract_type",
    "producer_repo",
    "consumer_repos",
    "version",
    "compatibility",
    "breaking_change_policy",
    "verification"
  ],
  "properties": {
    "schema_version": { "const": "shirube-contract/v1" },
    "CONTRACT-ID": { "type": "string", "pattern": "^CONTRACT-[A-Z0-9-]+$" },
    "contract_type": {
      "enum": [
        "api",
        "mcp_tool",
        "memory_schema",
        "event_schema",
        "prompt_io",
        "version_compatibility"
      ]
    },
    "producer_repo": { "type": "string" },
    "consumer_repos": { "type": "array", "items": { "type": "string" } },
    "version": { "type": "string" },
    "schema_ref": { "type": "string" },
    "compatibility": { "type": "array", "items": { "type": "string" } },
    "breaking_change_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requires_spec", "requires_affected_cell_list", "requires_migration_plan", "requires_rollback_plan", "requires_consumer_repo_verification"],
      "properties": {
        "requires_spec": { "type": "boolean" },
        "requires_affected_cell_list": { "type": "boolean" },
        "requires_migration_plan": { "type": "boolean" },
        "requires_rollback_plan": { "type": "boolean" },
        "requires_consumer_repo_verification": { "type": "boolean" }
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "command_or_evidence", "result"],
        "properties": {
          "repo": { "type": "string" },
          "command_or_evidence": { "type": "string" },
          "result": { "enum": ["PASS", "FAIL", "N/A"] }
        }
      }
    }
  }
}
