{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/shirube/audit-unit.v1.schema.json",
  "title": "Shirube Audit Unit v1",
  "description": "Verification unit for one PR exact head that may cover one or more Cells.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "verdict",
    "would_block",
    "audit_unit_id",
    "target_pr",
    "exact_head_sha",
    "covered_cells",
    "audit_item_sets",
    "review_plan_ref",
    "owner_decision_scope",
    "blockers",
    "warnings",
    "generated_at"
  ],
  "properties": {
    "schema": { "const": "shirube-audit-unit/v1" },
    "verdict": { "enum": ["PASS", "PASS_WITH_WARN", "BLOCKED", "FAILURE"] },
    "would_block": { "type": "boolean" },
    "audit_unit_id": {
      "type": ["string", "null"]
    },
    "target_pr": { "type": "integer", "minimum": 1 },
    "exact_head_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "covered_cells": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^CELL-[A-Z0-9._:-]+$" }
    },
    "audit_item_sets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_plan_ref": {
      "type": ["string", "null"]
    },
    "owner_decision_scope": { "const": "pr_exact_head" },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "generated_at": { "type": "string" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["item_id", "code", "path", "message"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
