{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchout.dev/schemas/shirube/cell-lifecycle.v1.schema.json",
  "title": "Shirube Cell Lifecycle",
  "type": "object",
  "required": [
    "schema_version",
    "cell_id",
    "cell_goal",
    "stage",
    "stage_order",
    "completes_cell",
    "cell_completion_definition"
  ],
  "properties": {
    "schema_version": {
      "const": "shirube-cell-lifecycle/v1"
    },
    "cell_id": {
      "type": "string",
      "pattern": "^CELL-[A-Z0-9][A-Z0-9_-]*$"
    },
    "cell_goal": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "enum": [
        "route_metadata",
        "implementation",
        "verification",
        "docs",
        "evidence_completion",
        "canary",
        "activation",
        "post_merge"
      ]
    },
    "stage_order": {
      "type": "integer",
      "minimum": 1
    },
    "completes_cell": {
      "type": "boolean"
    },
    "next_stage": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "route_metadata",
        "implementation",
        "verification",
        "docs",
        "evidence_completion",
        "canary",
        "activation",
        "post_merge",
        null
      ]
    },
    "next_expected_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_expected_command": {
      "type": "string"
    },
    "cell_completion_definition": {
      "type": "string",
      "minLength": 1
    },
    "implementation_plan_mode": {
      "enum": [
        "single_pr",
        "multi_pr"
      ]
    },
    "planned_pr_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
