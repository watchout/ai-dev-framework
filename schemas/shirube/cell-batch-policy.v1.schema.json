{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/shirube/cell-batch-policy.v1.schema.json",
  "title": "Shirube Cell Batch Policy v1",
  "description": "Deterministic policy result that decides whether multiple Cells may be delivered in one PR unit.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "verdict",
    "would_block",
    "batch_allowed",
    "batch_reason_codes",
    "batch_id",
    "covered_cells",
    "required_pr_count",
    "required_audit_count",
    "review_plan_profile",
    "blockers",
    "warnings",
    "generated_at"
  ],
  "properties": {
    "schema": { "const": "shirube-cell-batch-policy/v1" },
    "verdict": { "enum": ["PASS", "PASS_WITH_WARN", "BLOCKED", "FAILURE"] },
    "would_block": { "type": "boolean" },
    "batch_allowed": { "type": "boolean" },
    "batch_reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "batch_id": {
      "type": ["string", "null"]
    },
    "covered_cells": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CELL-[A-Z0-9._:-]+$" }
    },
    "required_pr_count": { "type": "integer", "minimum": 1 },
    "required_audit_count": { "type": "integer", "minimum": 1 },
    "review_plan_profile": {
      "enum": ["docs_light", "standard", "runtime_policy_standard", "protected"]
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "generated_at": { "type": "string" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["item_id", "code", "path", "message"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
