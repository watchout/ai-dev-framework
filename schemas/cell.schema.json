{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/cell.schema.json",
  "title": "Shirube Cell",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "CELL-ID",
    "SPEC-ID",
    "risk_tier",
    "goal",
    "covered_req_ids",
    "allowed_paths",
    "forbidden_paths",
    "acceptance_criteria",
    "required_tests",
    "required_evidence",
    "non_goals",
    "stop_conditions",
    "execution_contract"
  ],
  "properties": {
    "schema_version": { "const": "shirube-cell/v1" },
    "CELL-ID": { "type": "string", "pattern": "^CELL-[A-Z0-9-]+$" },
    "SPEC-ID": { "type": "string", "pattern": "^SPEC-[A-Z0-9-]+$" },
    "risk_tier": { "enum": ["R0", "R1", "R2", "R3"] },
    "goal": { "type": "string", "minLength": 1 },
    "covered_req_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/acceptanceCriterion" } },
    "required_tests": { "type": "array", "items": { "type": "string" } },
    "required_evidence": { "type": "array", "items": { "type": "string" } },
    "non_goals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "waiver_refs": { "type": "array", "items": { "type": "string" } },
    "execution_contract": { "$ref": "#/$defs/executionContract" }
  },
  "$defs": {
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "linked_req_ids"],
      "properties": {
        "id": { "type": "string" },
        "statement": { "type": "string" },
        "linked_req_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "executionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_term",
        "allowed_commands",
        "forbidden_commands",
        "handoff_conditions",
        "completion_evidence"
      ],
      "properties": {
        "canonical_term": { "const": "Goal-directed bounded execution" },
        "shorthand": { "const": "Goal-mode Implementation" },
        "allowed_commands": { "type": "array", "items": { "type": "string" } },
        "forbidden_commands": { "type": "array", "items": { "type": "string" } },
        "handoff_conditions": { "type": "array", "items": { "type": "string" } },
        "completion_evidence": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
