{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/audit-result.schema.json",
  "title": "Shirube Audit Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "AUDIT-ID",
    "audit_type",
    "target_refs",
    "verdict",
    "findings",
    "auditor",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "shirube-audit-result/v1" },
    "AUDIT-ID": { "type": "string", "pattern": "^AUDIT-[A-Z0-9-]+$" },
    "audit_type": {
      "enum": [
        "spec-audit",
        "spec-to-cell-trace-audit",
        "impl-audit",
        "impl-to-code-audit",
        "mcp-security-audit",
        "memory-privacy-audit",
        "post-merge-verification-audit"
      ]
    },
    "target_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "verdict": { "enum": ["PASS", "FAIL", "N/A"] },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "auditor": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "calibration_case_ref": { "type": "string" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "result", "evidence"],
      "properties": {
        "check_id": { "type": "string" },
        "result": { "enum": ["PASS", "FAIL", "N/A"] },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  }
}
