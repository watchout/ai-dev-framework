{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shirube.dev/schemas/repo-spec.schema.json",
  "title": "Shirube Repository Premise Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repo_id",
    "purpose",
    "non_goals",
    "design_principles",
    "development_flow",
    "roles",
    "boundaries",
    "required_gates",
    "standards",
    "agent_policy_ref"
  ],
  "properties": {
    "schema_version": { "const": "shirube-repo-spec/v1" },
    "repo_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string" },
    "purpose": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "non_goals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "design_principles": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "development_flow": {
      "type": "array",
      "minItems": 6,
      "items": {
        "enum": ["Spec", "Cell", "Impl", "Code", "Test", "Evidence"]
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "required": ["repo_owner", "release_owner", "security_owner", "evidence_owner"]
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "forbidden_paths", "data_boundaries", "dependency_boundaries", "forbidden_actions"],
      "properties": {
        "allowed_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } },
        "data_boundaries": { "type": "array", "items": { "type": "string" } },
        "dependency_boundaries": { "type": "array", "items": { "type": "string" } },
        "forbidden_actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "required_gates": { "type": "array", "items": { "type": "string" } },
    "risk_tier_defaults": { "$ref": "#/$defs/riskTier" },
    "standards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["soc2", "iso_iec_42001", "engineering_references"],
      "properties": {
        "soc2": { "type": "array", "items": { "type": "string" } },
        "iso_iec_42001": { "type": "string" },
        "engineering_references": { "type": "array", "items": { "enum": ["NIST_SSDF", "OWASP_LLM_TOP_10", "SLSA"] } }
      }
    },
    "ai_usage_classification": { "type": "string" },
    "agent_policy_ref": { "type": "string", "minLength": 1 },
    "evidence_ledger_ref": { "type": "string" }
  },
  "$defs": {
    "riskTier": {
      "enum": ["R0", "R1", "R2", "R3"]
    }
  }
}
