{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://watchout.github.io/shirube/schemas/ai-change-record.schema.json",
  "title": "Shirube AIChangeRecord",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "prId",
    "aiProvider",
    "promptHash",
    "gateResults",
    "humanReviewedAt",
    "sessionId",
    "providerId",
    "taskId",
    "timestamp",
    "changes",
    "tierDeclared",
    "tierEffective",
    "protectedCategoriesTriggered",
    "gateOutcome"
  ],
  "properties": {
    "schemaVersion": { "const": "ai-change-record/v1" },
    "prId": { "type": "string", "minLength": 1 },
    "aiProvider": { "type": "string", "minLength": 1 },
    "promptHash": { "type": "string", "minLength": 1 },
    "gateResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gateId", "status"],
        "properties": {
          "gateId": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "pending", "unknown"]
          },
          "checkedAt": { "type": "string", "format": "date-time" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failures": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "humanReviewedAt": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "sessionId": { "type": "string", "minLength": 1 },
    "providerId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "commitSha": { "type": "string" },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "linesAdded", "linesRemoved", "changeType"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "linesAdded": { "type": "integer", "minimum": 0 },
          "linesRemoved": { "type": "integer", "minimum": 0 },
          "changeType": {
            "type": "string",
            "enum": ["create", "modify", "delete"]
          }
        }
      }
    },
    "tierDeclared": { "type": "string", "enum": ["nano", "standard", "full"] },
    "tierEffective": { "type": "string", "enum": ["nano", "standard", "full"] },
    "protectedCategoriesTriggered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gateOutcome": { "type": "string", "enum": ["pass", "fail", "skip"] },
    "evidenceRef": { "type": "string" }
  }
}
