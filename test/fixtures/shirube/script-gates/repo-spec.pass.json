{
  "schema_version": "shirube-repo-spec/v1",
  "repo_id": "watchout/ai-dev-framework",
  "repo": "watchout/ai-dev-framework",
  "canonical_core": "watchout/ai-dev-framework@abc123",
  "purpose": "Fixture repo spec.",
  "non_goals": [],
  "design_principles": ["Machine evidence is primary."],
  "development_flow": "docs/standards/shirube-ai-development-governance-standard-v1.md",
  "required_gates": ["repo_spec", "planning"],
  "roles": {
    "spec": "spec",
    "arc": "arc",
    "design_reviewer": "design",
    "impl_runner": "runner",
    "impl_reviewer": "reviewer",
    "release_owner": "owner"
  },
  "codeowners_ref": "CODEOWNERS",
  "audit_responsibilities": "Audit responsibilities.",
  "shared_terminology": { "Cell": "Bounded implementation unit." },
  "security_assumptions": "Security assumptions.",
  "privacy_assumptions": "Privacy assumptions.",
  "data_boundaries": ["No customer data."],
  "dependency_boundaries": ["No new dependencies."],
  "forbidden_actions": ["No protected settings mutation."],
  "ai_usage_classification": "agentic",
  "soc2_categories": ["Security", "Confidentiality", "Processing Integrity"],
  "iso42001_applicability": true,
  "agent_permission_boundary": {
    "allowed_paths": [".shirube/**"],
    "forbidden_paths": [".env"],
    "allowed_commands": ["node scripts/shirube/check-repo-spec.mjs"],
    "forbidden_commands": ["gh pr merge"],
    "allowed_mcp_tools": [],
    "approval_required_mcp_tools": [],
    "forbidden_mcp_tools": []
  },
  "audit_assignment": {
    "schema_version": "shirube-audit-assignment/v1",
    "source_ref": "https://github.com/watchout/ai-dev-framework/issues/450#issuecomment-4761272721",
    "author_must_not_audit_own_artifact": true,
    "roles": {
      "spec": {
        "responsibility": "dispatch_author_only",
        "may_audit": false
      },
      "arc": {
        "responsibility": "design_input_and_encode_only",
        "may_audit": false
      },
      "codex_audit": {
        "responsibility": "formal_audit_gate",
        "may_audit": true
      },
      "bridge": {
        "responsibility": "machine_admissibility_gate"
      },
      "cto": {
        "responsibility": "r3_r4_governance_authority"
      },
      "ceo": {
        "responsibility": "route_ceo_approval_and_rps_confirmation"
      }
    },
    "artifacts": {
      "premise_rps": {
        "audit_role": "codex-audit",
        "design_input_role": "arc",
        "author_role": "spec",
        "gate": "formal_rps_design_audit"
      },
      "feature_spec": {
        "audit_role": "codex-audit"
      },
      "cell": {
        "audit_role": "codex-audit"
      },
      "impl_to_code": {
        "audit_role": "codex-audit"
      },
      "bridge_admissibility": {
        "audit_role": "codex-audit",
        "machine_gate": "bridge"
      },
      "route_ceo_approval": {
        "authority_roles": ["CEO", "CTO when R3/R4 governance applies"]
      },
      "enforce": {
        "authority_roles": ["CEO", "CTO when R3/R4 governance applies"]
      }
    }
  },
  "confirmation_evidence": {
    "rps_readiness": {
      "required": true,
      "authority_role": "CEO",
      "authority_actor": "watchout",
      "canonical_artifact_path": ".shirube/evidence/rps-confirmation.yaml",
      "accepted_sinks": ["repository_file", "github_issue_comment", "github_pr_comment"],
      "github_marker": "shirube:rps-confirmation/v1",
      "required_fields": [
        "schema_version",
        "record_id",
        "repo",
        "rps_id",
        "source_pr",
        "exact_head_sha",
        "authority_role",
        "authority_actor",
        "verdict",
        "created_at",
        "evidence_refs"
      ],
      "valid_verdicts": ["CONFIRMED", "CHANGES_REQUIRED", "BLOCKED"]
    }
  },
  "remediation": {
    "repo-spec": {
      "on_fail": "Fix repo spec.",
      "doc_ref": "templates/shirube-repo-spec.yaml"
    }
  }
}
